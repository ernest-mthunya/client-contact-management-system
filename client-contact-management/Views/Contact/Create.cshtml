@model ContactRequest

@{
    ViewData["Title"] = "New Contact";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="text-muted small text-decoration-none">← Contacts</a>
            <h2 class="mb-0 mt-1">New Contact</h2>
        </div>
    </div>

    <ul class="nav nav-tabs mb-0">
        <li class="nav-item">
            <button class="nav-link active">General</button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-4 bg-white shadow-sm">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3" style="max-width:480px">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3" style="max-width:480px">
                <label asp-for="Surname" class="form-label fw-semibold"></label>
                <input asp-for="Surname" class="form-control" />
                <span asp-validation-for="Surname" class="text-danger small"></span>
            </div>

            <div class="mb-3" style="max-width:480px">
                <label asp-for="Email" class="form-label fw-semibold"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
