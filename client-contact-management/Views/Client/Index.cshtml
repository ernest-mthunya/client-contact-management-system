@model IEnumerable<ClientResponse>

<div class="container mt-4">
    <div class="d-flex justify-content-between mb-3">
        <h2>Clients</h2>
        <a asp-controller="Client" asp-action="Create" class="btn btn-primary">Create New Client</a>
    </div>

    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Linked Contacts</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ClientCode</td>
                    <td>@item.Name</td>
                    <td><span class="badge bg-info">@item.NumberOfContactLinked</span></td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>