@model IEnumerable<ClientResponse>

@{
    ViewData["Title"] = "Clients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Clients</h2>
        <a asp-action="Create" class="btn btn-primary">+ New Client</a>
    </div>

    @if (!Model.Any())
    {
        <p class="text-muted fst-italic">No client(s) found.</p>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="text-align:left">Name</th>
                    <th style="text-align:left">Client Code</th>
                    <th style="text-align:center">No. of linked contacts</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td style="text-align:left">@client.Name</td>
                        <td style="text-align:left">@client.ClientCode</td>
                        <td style="text-align:center">@client.NumberOfContactLinked</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
